[node name="Controls" type="Label" parent="Margin/VBox/PageScroll/Page"]
layout_mode = 2
text = "CO-OP CARD BRAWL  (2 players, one shared deck)
P1 = keyboard + mouse      P2 = gamepad (left stick move, right stick aim)
Move your egg, Left-Click / right-trigger to attack, C / gamepad-A to cast a granted ability
In the PAUSE: pick a card, then choose WHERE to use it —
  · weapon / ability  → click one of your eggs (hero or a soldier)
  · soldier  → click a glowing spot beside an egg you control (build a squad, no overlap)
Selected cards stay in hand — click again to unselect.  Each player has their OWN energy.
End Turn → a 3-2-1 countdown, then survive the 15s wave.  You lose only when BOTH eggs fall.
R — restart      Esc — pause / quit to menu"
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.62, 0.64, 0.7, 1)
theme_override_font_sizes/font_size = 15
